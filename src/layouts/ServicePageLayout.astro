---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import ButtonLink from '../components/ButtonLink.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import LogoLockup from '../components/LogoLockup.astro';
import SectionIntro from '../components/SectionIntro.astro';
import ogImage from '../assets/og-image.jpg';
import { contactEmail, extendedServiceAreaName, optionalEventVenueSchema, postalAddress, serviceAreaName, siteUrl, venueName } from '../lib/site';

interface ContentBlock {
  title: string;
  body: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface RelatedLink {
  href: string;
  label: string;
  text: string;
}

interface Props {
  slug: string;
  pageTitle: string;
  pageDescription: string;
  eyebrow: string;
  heading: string;
  intro: string;
  image: ImageMetadata;
  imageAlt: string;
  serviceName: string;
  serviceType: string;
  highlights: string[];
  contentBlocks: ContentBlock[];
  faqItems: FaqItem[];
  relatedLinks: RelatedLink[];
}

const {
  slug,
  pageTitle,
  pageDescription,
  eyebrow,
  heading,
  intro,
  image,
  imageAlt,
  serviceName,
  serviceType,
  highlights,
  contentBlocks,
  faqItems,
  relatedLinks,
} = Astro.props;

const canonicalUrl = `${siteUrl}/${slug}/`;
const fallbackOgImageUrl = new URL(ogImage.src, siteUrl).toString();
const pageImageUrl = new URL(image.src, siteUrl).toString();
const pageImageWidth = image.width ?? 1200;
const pageImageHeight = image.height ?? 630;

const structuredData = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${canonicalUrl}#webpage`,
    url: canonicalUrl,
    name: pageTitle,
    description: pageDescription,
    inLanguage: 'en-CA',
    isPartOf: {
      '@id': `${siteUrl}/#website`,
    },
    mainEntity: {
      '@id': `${canonicalUrl}#service`,
    },
    primaryImageOfPage: {
      '@type': 'ImageObject',
      url: pageImageUrl,
      width: pageImageWidth,
      height: pageImageHeight,
      caption: imageAlt,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': `${canonicalUrl}#service`,
    name: serviceName,
    serviceType,
    description: pageDescription,
    url: canonicalUrl,
    image: pageImageUrl,
    provider: {
      '@type': 'EventVenue',
      '@id': `${siteUrl}/#eventvenue`,
      name: venueName,
      url: siteUrl,
      email: contactEmail,
      image: fallbackOgImageUrl,
      address: postalAddress,
      ...optionalEventVenueSchema,
    },
    areaServed: {
      '@type': 'AdministrativeArea',
      name: serviceAreaName,
    },
    availableChannel: {
      '@type': 'ServiceChannel',
      serviceUrl: `${canonicalUrl}#contact`,
      availableLanguage: ['en-CA'],
    },
    audience: {
      '@type': 'Audience',
      geographicArea: {
        '@type': 'AdministrativeArea',
        name: extendedServiceAreaName,
      },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: venueName,
        item: `${siteUrl}/`,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: serviceName,
        item: canonicalUrl,
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    '@id': `${canonicalUrl}#faq`,
    url: `${canonicalUrl}#faq`,
    inLanguage: 'en-CA',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
]);
---

<BaseLayout
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  canonicalUrl={canonicalUrl}
  ogImageUrl={pageImageUrl}
  ogImageAlt={imageAlt}
  structuredData={structuredData}
  venueName={venueName}
  ogImageWidth={pageImageWidth}
  ogImageHeight={pageImageHeight}
>
  <Fragment slot="before-main">
    <header class="container-shell pt-8 md:pt-12">
      <nav class="flex items-center justify-between gap-6" aria-label="Service page">
        <LogoLockup variant="header" href="/" />
        <ButtonLink href="#contact" variant="nav">Inquire</ButtonLink>
      </nav>
    </header>
  </Fragment>

      <section class="container-shell grid gap-10 py-14 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:py-20">
        <div class="flex flex-col gap-6">
          <p class="text-[12px] leading-4 font-[400] tracking-[2.4px] uppercase text-[color:var(--color-body)]">{eyebrow}</p>
          <div class="flex flex-col gap-5">
            <h1 class="text-balance font-['Fraunces'] text-[clamp(2.6rem,6vw,5.25rem)] leading-[1.08] font-[300] text-[color:var(--color-brand)]">{heading}</h1>
            <p class="max-w-[720px] text-[18px] leading-8 text-[color:var(--color-body)]">{intro}</p>
          </div>
          <div class="flex flex-wrap gap-3">
            <ButtonLink href="#contact">Start planning</ButtonLink>
            <ButtonLink href="/" variant="secondary">Back to home</ButtonLink>
          </div>
        </div>

        <div class="overflow-hidden rounded-2xl bg-[color:var(--color-space-card)]">
          <Image
            src={image}
            alt={imageAlt}
            width={900}
            height={620}
            widths={[640, 900, 1280]}
            sizes="(min-width: 1024px) 50vw, 100vw"
            format="webp"
            quality={78}
            class="h-[320px] w-full object-cover md:h-[460px] lg:h-[560px]"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </section>

      <section class="w-full bg-[color:var(--color-space-card)] py-16 md:py-20">
        <div class="container-shell grid gap-6 md:grid-cols-3">
          {
            highlights.map((highlight) => (
              <article class="rounded-2xl bg-[color:var(--color-white)] p-[25px]">
                <p class="text-[16px] leading-[26px] text-[color:var(--color-body)]">{highlight}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="container-shell py-16 md:py-20">
        <div class="grid gap-10 lg:grid-cols-[0.7fr_1.3fr]">
          <SectionIntro eyebrow="Planning Details" heading="A venue experience shaped around your event" maxWidthClass="max-w-[420px]" class="gap-3" />
          <div class="grid gap-8">
            {
              contentBlocks.map((block) => (
                <article class="border-b border-[color:var(--color-space-card)] pb-8 last:border-b-0 last:pb-0">
                  <h3 class="text-balance text-[24px] leading-8 font-[400] text-[color:var(--color-heading)]">{block.title}</h3>
                  <p class="mt-3 text-[16px] leading-[28px] text-[color:var(--color-body)]">{block.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="w-full bg-[color:var(--color-amenity-bg)] py-16 md:py-20">
        <div class="container-shell">
          <SectionIntro eyebrow="Related Spaces" heading="Explore more ways to host at Legacy Events" eyebrowColor="brand" maxWidthClass="max-w-[620px]" class="mb-8" />
          <div class="grid gap-6 md:grid-cols-2">
            {
              relatedLinks.map((link) => (
                <a href={link.href} class="focus-ring rounded-2xl bg-[color:var(--color-amenity-card)] p-[25px] text-[color:var(--color-heading)] no-underline transition [transition-property:transform,filter] hover:brightness-[0.98] hover:-translate-y-px motion-reduce:transition-none motion-reduce:hover:translate-y-0">
                  <h3 class="text-[22px] leading-7 font-[400]">{link.label}</h3>
                  <p class="mt-2 text-[16px] leading-[26px] text-[color:var(--color-body)]">{link.text}</p>
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <FaqAccordion items={faqItems} heading={`Questions about ${serviceName.toLowerCase()}`} idPrefix={`${slug}-faq`} sectionId="faq" />
</BaseLayout>
