---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/global.css';
import FaqAccordion from '../components/FaqAccordion.astro';
import Footer from '../components/Footer.astro';
import logoMark from '../assets/logo-mark.svg';
import ogImage from '../assets/og-image.jpg';

interface ContentBlock {
  title: string;
  body: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface RelatedLink {
  href: string;
  label: string;
  text: string;
}

interface Props {
  slug: string;
  pageTitle: string;
  pageDescription: string;
  eyebrow: string;
  heading: string;
  intro: string;
  image: ImageMetadata;
  imageAlt: string;
  serviceName: string;
  serviceType: string;
  highlights: string[];
  contentBlocks: ContentBlock[];
  faqItems: FaqItem[];
  relatedLinks: RelatedLink[];
}

const {
  slug,
  pageTitle,
  pageDescription,
  eyebrow,
  heading,
  intro,
  image,
  imageAlt,
  serviceName,
  serviceType,
  highlights,
  contentBlocks,
  faqItems,
  relatedLinks,
} = Astro.props;

const venueName = 'Legacy Events';
const siteUrl = (import.meta.env.SITE ?? 'https://legacyevents.ca').replace(/\/$/, '');
const canonicalUrl = `${siteUrl}/${slug}/`;
const fallbackOgImageUrl = new URL(ogImage.src, siteUrl).toString();
const pageImageUrl = new URL(image.src, siteUrl).toString();
const pageImageWidth = image.width ?? 1200;
const pageImageHeight = image.height ?? 630;
const contactEmail = 'Info@legacyeventsbelleville.onmicrosoft.com';

const structuredData = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${canonicalUrl}#webpage`,
    url: canonicalUrl,
    name: pageTitle,
    description: pageDescription,
    inLanguage: 'en-CA',
    isPartOf: {
      '@id': `${siteUrl}/#website`,
    },
    mainEntity: {
      '@id': `${canonicalUrl}#service`,
    },
    primaryImageOfPage: {
      '@type': 'ImageObject',
      url: pageImageUrl,
      width: pageImageWidth,
      height: pageImageHeight,
      caption: imageAlt,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': `${canonicalUrl}#service`,
    name: serviceName,
    serviceType,
    description: pageDescription,
    url: canonicalUrl,
    image: pageImageUrl,
    provider: {
      '@type': 'EventVenue',
      '@id': `${siteUrl}/#eventvenue`,
      name: venueName,
      url: siteUrl,
      email: contactEmail,
      image: fallbackOgImageUrl,
      address: {
        '@type': 'PostalAddress',
        streetAddress: '4211 Old Highway 2',
        addressLocality: 'Belleville',
        addressRegion: 'ON',
        postalCode: 'K8N 4Z4',
        addressCountry: 'CA',
      },
    },
    areaServed: {
      '@type': 'AdministrativeArea',
      name: 'Belleville and Quinte region',
    },
    availableChannel: {
      '@type': 'ServiceChannel',
      serviceUrl: `${canonicalUrl}#contact`,
      availableLanguage: ['en-CA'],
    },
    audience: {
      '@type': 'Audience',
      geographicArea: {
        '@type': 'AdministrativeArea',
        name: 'Belleville and the Quinte region',
      },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: venueName,
        item: `${siteUrl}/`,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: serviceName,
        item: canonicalUrl,
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    '@id': `${canonicalUrl}#faq`,
    url: `${canonicalUrl}#faq`,
    inLanguage: 'en-CA',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
]);
---

<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    <link rel="apple-touch-icon" href="/assets/favicon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1e4192" />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={pageDescription} />
    <meta name="author" content={venueName} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en-CA" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={venueName} />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={pageImageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content={String(pageImageWidth)} />
    <meta property="og:image:height" content={String(pageImageHeight)} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs Guidance" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400&family=Inter:opsz,wght@14..32,100..900&display=swap"
      rel="stylesheet"
    />
    <script is:inline type="application/ld+json" set:html={structuredData}></script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header class="container-shell pt-8 md:pt-12">
      <nav class="flex items-center justify-between gap-6" aria-label="Service page">
        <a href="/" class="focus-ring inline-flex items-center gap-3 rounded-sm text-[color:var(--color-brand)] no-underline">
          <Image src={logoMark} alt="Legacy Events script monogram logo" width={71} height={72} class="h-11 w-11 md:h-14 md:w-14" loading="eager" />
          <span class="font-['Fraunces'] text-[18px] font-[300] tracking-[2.4px]">LEGACY EVENTS</span>
        </a>
        <a href="#contact" class="focus-ring hidden cursor-pointer rounded-full bg-[color:var(--color-brand)] px-5 py-2.5 text-[14px] font-[700] text-white no-underline transition [transition-property:transform,filter] hover:brightness-[0.94] hover:-translate-y-px motion-reduce:transition-none motion-reduce:hover:translate-y-0 md:inline-flex">Inquire</a>
      </nav>
    </header>

    <main id="main-content">
      <section class="container-shell grid gap-10 py-14 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:py-20">
        <div class="flex flex-col gap-6">
          <p class="text-[12px] leading-4 font-[400] tracking-[2.4px] uppercase text-[color:var(--color-body)]">{eyebrow}</p>
          <div class="flex flex-col gap-5">
            <h1 class="text-balance font-['Fraunces'] text-[clamp(2.6rem,6vw,5.25rem)] leading-[1.08] font-[300] text-[color:var(--color-brand)]">{heading}</h1>
            <p class="max-w-[720px] text-[18px] leading-8 text-[color:var(--color-body)]">{intro}</p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="#contact" class="focus-ring inline-flex cursor-pointer items-center justify-center rounded-full bg-[color:var(--color-brand)] px-8 py-3 text-[16px] leading-6 font-[700] text-white no-underline transition [transition-property:transform,filter] hover:brightness-[0.94] hover:-translate-y-px motion-reduce:transition-none motion-reduce:hover:translate-y-0">Start planning</a>
            <a href="/" class="focus-ring inline-flex cursor-pointer items-center justify-center rounded-full border border-[color:var(--color-brand)] px-8 py-3 text-[16px] leading-6 font-[700] text-[color:var(--color-brand)] no-underline transition [transition-property:transform,background-color] hover:bg-[color:var(--color-space-card)] hover:-translate-y-px motion-reduce:transition-none motion-reduce:hover:translate-y-0">Back to home</a>
          </div>
        </div>

        <div class="overflow-hidden rounded-2xl bg-[color:var(--color-space-card)]">
          <Image
            src={image}
            alt={imageAlt}
            width={900}
            height={620}
            widths={[640, 900, 1280]}
            sizes="(min-width: 1024px) 50vw, 100vw"
            format="webp"
            quality={78}
            class="h-[320px] w-full object-cover md:h-[460px] lg:h-[560px]"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </section>

      <section class="w-full bg-[color:var(--color-space-card)] py-16 md:py-20">
        <div class="container-shell grid gap-6 md:grid-cols-3">
          {
            highlights.map((highlight) => (
              <article class="rounded-2xl bg-[color:var(--color-white)] p-[25px]">
                <p class="text-[16px] leading-[26px] text-[color:var(--color-body)]">{highlight}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="container-shell py-16 md:py-20">
        <div class="grid gap-10 lg:grid-cols-[0.7fr_1.3fr]">
          <div class="flex max-w-[420px] flex-col gap-3">
            <p class="text-[12px] leading-4 font-[400] tracking-[2.4px] uppercase text-[color:var(--color-body)]">Planning Details</p>
            <h2 class="text-balance text-[clamp(1.9rem,2.7vw,2.25rem)] leading-[1.12] font-[400] text-[color:var(--color-heading)]">A venue experience shaped around your event</h2>
          </div>
          <div class="grid gap-8">
            {
              contentBlocks.map((block) => (
                <article class="border-b border-[color:var(--color-space-card)] pb-8 last:border-b-0 last:pb-0">
                  <h3 class="text-balance text-[24px] leading-8 font-[400] text-[color:var(--color-heading)]">{block.title}</h3>
                  <p class="mt-3 text-[16px] leading-[28px] text-[color:var(--color-body)]">{block.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="w-full bg-[color:var(--color-amenity-bg)] py-16 md:py-20">
        <div class="container-shell">
          <div class="mb-8 flex max-w-[620px] flex-col gap-2">
            <p class="text-[12px] leading-4 font-[400] tracking-[2.4px] uppercase text-[color:var(--color-brand)]">Related Spaces</p>
            <h2 class="text-balance text-[clamp(1.9rem,2.7vw,2.25rem)] leading-[1.12] font-[400] text-[color:var(--color-heading)]">Explore more ways to host at Legacy Events</h2>
          </div>
          <div class="grid gap-6 md:grid-cols-2">
            {
              relatedLinks.map((link) => (
                <a href={link.href} class="focus-ring rounded-2xl bg-[color:var(--color-amenity-card)] p-[25px] text-[color:var(--color-heading)] no-underline transition [transition-property:transform,filter] hover:brightness-[0.98] hover:-translate-y-px motion-reduce:transition-none motion-reduce:hover:translate-y-0">
                  <h3 class="text-[22px] leading-7 font-[400]">{link.label}</h3>
                  <p class="mt-2 text-[16px] leading-[26px] text-[color:var(--color-body)]">{link.text}</p>
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <FaqAccordion items={faqItems} heading={`Questions about ${serviceName.toLowerCase()}`} idPrefix={`${slug}-faq`} sectionId="faq" />
    </main>

    <Footer />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
