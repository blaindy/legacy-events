---
import ContactForm from './ContactForm.astro';
import LocationMap from './LocationMap.astro';
import { venueName } from '../lib/site';

const currentYear = new Date().getFullYear();
---

<footer id="contact" class="bg-[color:var(--color-brand)] py-16 text-white">
  <div class="container-shell">
    <div class="grid gap-8 lg:grid-cols-2">
      <ContactForm />
      <LocationMap />
    </div>

    <p class="mt-20 text-[14px] leading-5 text-[color:var(--color-footer-subtle)] md:mt-10">© {currentYear} {venueName}. All rights reserved.</p>
  </div>
</footer>
