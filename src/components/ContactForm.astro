---
import { venueName, web3formsKey } from '../lib/site';
---

<section aria-labelledby="contact-heading">
  <div class="flex flex-col gap-2">
    <h2 id="contact-heading" class="text-balance text-[24px] leading-8 font-[400] text-[color:var(--color-footer-light)]">Contact us</h2>
    <p id="contact-intro" class="text-[16px] leading-[26px] text-[color:var(--color-footer-subtle)]">
      Share your event details and we will contact you within one business day.
    </p>
  </div>

  <form id="contact-form" class="mt-6 space-y-4" method="POST" action="https://api.web3forms.com/submit" novalidate aria-describedby="contact-intro">
    <input type="hidden" name="access_key" value={web3formsKey} />
    <input type="hidden" name="subject" value={`New inquiry from ${venueName} website`} />
    <input type="hidden" name="from_name" value={venueName} />

    <div>
      <label for="name" class="mb-1 block text-[14px] leading-5 font-[400] text-[color:var(--color-footer-light)]">Name</label>
      <input
        id="name"
        name="name"
        type="text"
        autocomplete="name"
        required
        class="focus-ring w-full rounded-lg border border-white/20 bg-[color:var(--color-white)] px-3 py-[9px] text-[16px] leading-[26px] text-[color:var(--color-heading)] placeholder:text-[color:var(--color-placeholder)]"
        placeholder="Your full name"
      />
    </div>

    <div>
      <label for="email" class="mb-1 block text-[14px] leading-5 font-[400] text-[color:var(--color-footer-light)]">Email</label>
      <input
        id="email"
        name="email"
        type="email"
        autocomplete="email"
        required
        class="focus-ring w-full rounded-lg border border-white/20 bg-[color:var(--color-white)] px-3 py-[9px] text-[16px] leading-[26px] text-[color:var(--color-heading)] placeholder:text-[color:var(--color-placeholder)]"
        placeholder="name@example.com"
      />
    </div>

    <div>
      <label for="message" class="mb-1 block text-[14px] leading-5 font-[400] text-[color:var(--color-footer-light)]">Message</label>
      <textarea
        id="message"
        name="message"
        rows="4"
        required
        class="focus-ring w-full rounded-lg border border-white/20 bg-[color:var(--color-white)] px-3 py-[9px] text-[16px] leading-[26px] text-[color:var(--color-heading)] placeholder:text-[color:var(--color-placeholder)]"
        placeholder="Tell us about your event date, guest count, and vision."
      ></textarea>
    </div>

    <button
      type="submit"
      class="focus-ring inline-flex cursor-pointer items-center justify-center rounded-full bg-white px-6 py-2.5 text-[16px] leading-6 font-[700] text-[color:var(--color-submit-text)] no-underline transition [transition-property:transform,filter] hover:brightness-[0.94] hover:-translate-y-px motion-reduce:transition-none motion-reduce:hover:translate-y-0 disabled:cursor-not-allowed"
    >
      Send Inquiry
    </button>

    <p id="form-status" class="min-h-[1.25rem] text-sm text-[color:var(--color-footer-light)]" role="status" aria-live="polite"></p>
  </form>

  <div
    id="form-success-panel"
    class="mt-6 hidden rounded-2xl bg-white/10 p-6 text-[color:var(--color-footer-light)]"
    role="status"
    aria-live="polite"
    aria-atomic="true"
    tabindex="-1"
  >
    <h3 class="text-balance text-xl leading-7 font-[400] text-[color:var(--color-footer-light)]">Inquiry sent</h3>
    <p class="mt-2 text-[16px] leading-[26px] text-[color:var(--color-footer-subtle)]">
      Thank you for reaching out. We will contact you within one business day.
    </p>
  </div>
</section>

<script>
  {
    const form = document.getElementById('contact-form');
    const status = document.getElementById('form-status');
    const successPanel = document.getElementById('form-success-panel');

    const setStatus = (text: string, isError = false) => {
      if (!(status instanceof HTMLElement)) return;
      status.textContent = text;
      status.classList.toggle('text-red-200', isError);
      status.classList.toggle('text-[color:var(--color-footer-light)]', !isError);
    };

    if (form instanceof HTMLFormElement) {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (!form.reportValidity()) {
          setStatus('Please complete all required fields.', true);
          return;
        }

        const accessKey = form.querySelector<HTMLInputElement>('input[name="access_key"]');
        if (!accessKey || !accessKey.value) {
          setStatus('Missing Web3Forms key. Set PUBLIC_WEB3FORMS_ACCESS_KEY in your environment.', true);
          return;
        }

        const submitButton = form.querySelector('button[type="submit"]');
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
          submitButton.setAttribute('aria-disabled', 'true');
          submitButton.textContent = 'Sending...';
        }
        form.setAttribute('aria-busy', 'true');

        try {
          const payload = new FormData(form);
          const response = await fetch(form.action, {
            method: 'POST',
            body: payload,
          });

          const result = await response.json();
          if (result.success) {
            form.reset();
            form.classList.add('hidden');
            setStatus('');
            if (successPanel instanceof HTMLElement) {
              successPanel.classList.remove('hidden');
              successPanel.focus();
            }
          } else {
            setStatus(result.message || 'Submission failed. Please try again.', true);
          }
        } catch {
          setStatus('Network error. Please try again in a moment.', true);
        } finally {
          form.setAttribute('aria-busy', 'false');
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = false;
            submitButton.removeAttribute('aria-disabled');
            submitButton.textContent = 'Send Inquiry';
          }
        }
      });
    }
  }
</script>
