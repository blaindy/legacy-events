---
import { Image } from 'astro:assets';
import mapImage from '../assets/map.png';
import { addressText, contactEmail, mapUrl } from '../lib/site';
---

<section class="flex flex-col gap-8" aria-labelledby="visit-heading">
  <div>
    <div class="flex flex-col gap-2">
      <h2 id="visit-heading" class="text-balance text-[24px] leading-8 font-[400] text-[color:var(--color-footer-light)]">Visit us</h2>
      <p class="text-[16px] leading-[26px] text-[color:var(--color-footer-subtle)]">
        Visit the venue and our team will gladly walk you through the space.
      </p>
    </div>
    <div class="mt-6 overflow-hidden rounded-2xl border border-white/20">
      <a
        class="focus-ring block"
        href={mapUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Open Legacy Events map in Google Maps (opens in a new tab)"
      >
        <Image
          src={mapImage}
          alt="Map showing Legacy Events location in Belleville, Ontario"
          width={556}
          height={350}
          widths={[420, 556, 900]}
          sizes="(min-width: 1024px) 50vw, 100vw"
          format="webp"
          quality={74}
          class="h-[312px] w-full object-cover md:h-[350px]"
          loading="lazy"
        />
      </a>
    </div>
  </div>

  <div>
    <p class="text-[14px] leading-5 text-[color:var(--color-footer-subtle)]">
      <a
        class="focus-ring rounded-sm underline-offset-4 hover:underline"
        href={mapUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Open Legacy Events location in Google Maps (opens in a new tab)"
      >
        {addressText}
      </a>
    </p>
    <p class="mt-4 text-[14px] leading-5 text-[color:var(--color-footer-subtle)]">
      <a class="focus-ring rounded-sm underline-offset-4 hover:underline" href={`mailto:${contactEmail}`}>{contactEmail}</a>
    </p>
  </div>
</section>
