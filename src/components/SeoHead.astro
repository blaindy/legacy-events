---
import { venueName as defaultVenueName } from '../lib/site';

interface Props {
  pageTitle: string;
  pageDescription: string;
  canonicalUrl: string;
  ogImageUrl: string;
  ogImageAlt: string;
  structuredData: string;
  venueName?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
}

const {
  pageTitle,
  pageDescription,
  canonicalUrl,
  ogImageUrl,
  ogImageAlt,
  structuredData,
  venueName = defaultVenueName,
  ogImageWidth = 1200,
  ogImageHeight = 630,
} = Astro.props;
---

<meta charset="utf-8" />
<link rel="icon" type="image/png" href="/assets/favicon.png" />
<link rel="apple-touch-icon" href="/assets/favicon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#1e4192" />
<meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
<meta name="generator" content={Astro.generator} />
<meta name="description" content={pageDescription} />
<meta name="author" content={venueName} />
<meta name="referrer" content="strict-origin-when-cross-origin" />
<link rel="canonical" href={canonicalUrl} />
<link rel="alternate" hreflang="en-CA" href={canonicalUrl} />
<link rel="alternate" hreflang="x-default" href={canonicalUrl} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content={venueName} />
<meta property="og:locale" content="en_CA" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDescription} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:width" content={String(ogImageWidth)} />
<meta property="og:image:height" content={String(ogImageHeight)} />
<meta property="og:image:alt" content={ogImageAlt} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDescription} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={ogImageAlt} />
<link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs Guidance" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400&family=Inter:opsz,wght@14..32,100..900&display=swap"
  rel="stylesheet"
/>
<script is:inline type="application/ld+json" set:html={structuredData}></script>
<title>{pageTitle}</title>
