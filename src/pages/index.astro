---
import { Image } from 'astro:assets';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/global.css';
import logoMark from '../assets/logo-mark.svg';
import heroImage from '../assets/hero.jpg';
import ogImage from '../assets/og-image.jpg';
import mapImage from '../assets/map.png';
import weddingsImage from '../assets/space-weddings.jpg';
import corporateImage from '../assets/space-corporate.jpg';
import privateImage from '../assets/space-private.jpg';
import cateringIcon from '../assets/amenity-catering.svg';
import avIcon from '../assets/amenity-av.svg';
import bridalIcon from '../assets/amenity-bridal.svg';
import valetIcon from '../assets/amenity-valet.svg';

const venueName = 'Legacy Events';
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';
const siteUrl = (import.meta.env.SITE ?? 'https://legacy-events-belleville.vercel.app').replace(/\/$/, '');
const pageTitle = `${venueName} | Event Venue in Belleville, ON`;
const pageDescription =
  `${venueName} hosts unforgettable weddings, corporate galas, and private celebrations in Belleville, Ontario.`;
const canonicalUrl = `${siteUrl}/`;
const ogImageUrl = new URL(ogImage.src, siteUrl).toString();
const currentYear = new Date().getFullYear();

const spaces = [
  {
    title: 'Weddings',
    image: weddingsImage,
    text: 'Romantic ballroom layouts, curated timelines, and personalized setup for ceremonies and receptions.',
  },
  {
    title: 'Corporate Galas',
    image: corporateImage,
    text: 'Professional staging with premium lighting and seamless service for awards, launches, and fundraisers.',
  },
  {
    title: 'Private Parties',
    image: privateImage,
    text: 'From anniversaries to milestone birthdays, celebrate with flexible spaces designed for elegant gatherings.',
  },
];

const amenities = [
  {
    name: 'In-house Catering',
    icon: cateringIcon,
    text: 'Seasonal menus, chef-led tastings, and polished table service tailored for every celebration style.',
  },
  {
    name: 'AV Equipment',
    icon: avIcon,
    text: 'Premium sound, discreet lighting, and seamless presentations managed by experts throughout your event.',
  },
  {
    name: 'Bridal Suite',
    icon: bridalIcon,
    text: 'Private prep spaces, calming details, and elegant mirrors designed for memorable wedding moments.',
  },
  {
    name: 'Valet Parking',
    icon: valetIcon,
    text: 'Welcoming arrivals, efficient routing, and attentive attendants ensuring smooth guest access all evening.',
  },
];

const testimonials = [
  {
    quote:
      'Our gala at Legacy Events was effortless from planning to final toast. The team delivered grace, precision, and unforgettable ambiance.',
    name: 'Jane Doe',
  },
  {
    quote:
      'From first walkthrough to last dance, every detail felt intentional. Guests still talk about the atmosphere and flawless service.',
    name: 'Michael R.',
  },
  {
    quote:
      'Legacy Events made our celebration feel elevated yet relaxed. The staff handled every transition smoothly and professionally.',
    name: 'Alicia T.',
  },
];

const structuredData = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'EventVenue',
  name: venueName,
  url: siteUrl,
  image: ogImageUrl,
  telephone: '+1-613-555-0148',
  email: 'events@legacyevents.com',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '1240 Dundas St E',
      addressLocality: 'Belleville',
      addressRegion: 'ON',
      postalCode: 'K8N 5R8',
      addressCountry: 'CA',
    },
  areaServed: 'Ontario',
  sameAs: ['https://instagram.com', 'https://facebook.com', 'https://linkedin.com'],
});
---

<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    <link rel="apple-touch-icon" href="/assets/favicon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1e4192" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={pageDescription} />
    <meta name="author" content={venueName} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en-CA" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={venueName} />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Elegant event ballroom at Legacy Events" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Elegant event ballroom at Legacy Events" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400&family=Inter:opsz,wght@14..32,100..900&display=swap"
      rel="stylesheet"
    />
    <script is:inline type="application/ld+json" set:html={structuredData}></script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <main id="main-content" tabindex="-1">
      <section aria-labelledby="hero-heading" class="container-shell flex flex-col items-center pt-10 md:pt-20">
        <div class="flex w-full max-w-[377px] flex-col items-center gap-5">
          <Image src={logoMark} alt="" aria-hidden="true" width={71} height={72} class="h-[48px] w-[47px] md:h-[72px] md:w-[71px]" loading="eager" />
          <p class="font-['Fraunces'] font-[300] text-[16px] tracking-[2px] text-[color:var(--color-brand)] md:text-[20px] md:tracking-[3px]">LEGACY EVENTS</p>
        </div>

        <div class="flex w-full max-w-[1152px] flex-col items-center justify-center gap-9 px-0 pt-12 pb-8">
          <h1 id="hero-heading" class="hero-title text-balance">Where your story<br />becomes a legacy.</h1>
          <a href="#contact" class="pill-button focus-ring bg-[color:var(--color-brand)] px-8 py-3 text-white" aria-label="Get in touch with Legacy Events">
            Get in touch
          </a>
        </div>
      </section>

      <section class="relative h-[390px] w-full overflow-hidden md:h-[550px]">
        <Image
          src={heroImage}
          alt=""
          aria-hidden="true"
          width={1920}
          height={550}
          widths={[768, 1280, 1920]}
          sizes="100vw"
          format="webp"
          quality={80}
          class="absolute inset-0 h-full w-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-white/100 from-[6.5%] to-transparent to-[55.5%]"></div>
      </section>

      <section aria-labelledby="spaces-heading" class="container-shell py-16 md:py-20">
        <div class="mb-10 flex w-full items-end">
          <div class="flex w-full max-w-[579px] flex-col gap-2">
            <p class="eyebrow">Our spaces</p>
            <h2 id="spaces-heading" class="section-title text-balance">Host every milestone beautifully</h2>
          </div>
        </div>

        <div
          id="spaces-carousel"
          class="mobile-carousel md:grid md:grid-cols-3"
          role="region"
          aria-labelledby="spaces-heading"
          tabindex="0"
        >
          {
            spaces.map((space) => (
              <article class="mobile-carousel-slide soft-card flex h-full flex-col gap-4 bg-[color:var(--color-space-card)] p-[25px]">
                <Image
                  src={space.image}
                  alt={`${space.title} event setup at ${venueName}`}
                  width={465}
                  height={286}
                  widths={[320, 465, 620]}
                  sizes="(min-width: 1024px) 30vw, 100vw"
                  format="webp"
                  quality={78}
                  class="h-[220px] w-full rounded-lg object-cover md:h-[286px]"
                  loading="lazy"
                />
                <h3 class="card-heading text-balance text-2xl leading-8">{space.title}</h3>
                <p class="body-copy">{space.text}</p>
              </article>
            ))
          }
        </div>
        <div id="spaces-dots" class="carousel-dots md:hidden" aria-label="Our spaces slide navigation"></div>
      </section>

      <section aria-labelledby="amenities-heading" class="w-full bg-[color:var(--color-amenity-bg)] py-16 md:py-20">
        <div class="container-shell">
          <div class="flex w-full max-w-[1152px] flex-col gap-2">
            <p class="eyebrow">Amenities</p>
            <h2 id="amenities-heading" class="section-title text-balance">Everything you need, in one venue</h2>
          </div>

          <div
            id="amenities-carousel"
            class="mobile-carousel mt-8 md:grid md:grid-cols-4"
            role="region"
            aria-labelledby="amenities-heading"
            tabindex="0"
          >
            {
              amenities.map((amenity) => (
                <article class="mobile-carousel-slide soft-card flex h-full flex-col gap-4 self-stretch bg-[color:var(--color-amenity-card)] p-[25px]">
                  <div class="inline-flex w-fit rounded-full bg-[color:var(--color-brand)] p-3">
                    <Image src={amenity.icon} alt="" width={32} height={32} class="h-8 w-8" loading="lazy" aria-hidden="true" />
                  </div>
                  <h3 class="card-heading text-balance text-[20px] leading-7">{amenity.name}</h3>
                  <p class="body-copy">{amenity.text}</p>
                </article>
              ))
            }
          </div>
          <div id="amenities-dots" class="carousel-dots md:hidden" aria-label="Amenities slide navigation"></div>
        </div>
      </section>

      <section aria-labelledby="testimonial-heading" class="container-shell py-16 md:py-20">
        <div class="mx-auto flex max-w-[1100px] flex-col items-center gap-7">
          <div class="h-[3px] w-24 rounded-full bg-[color:var(--color-amenity-bg)]"></div>
          <h2 id="testimonial-heading" class="sr-only text-balance">Testimonial</h2>

          <div
            id="testimonials-carousel"
            class="testimonial-carousel w-full max-w-[1100px]"
            role="region"
            aria-labelledby="testimonial-heading"
            tabindex="0"
          >
            {
              testimonials.map((testimonial) => (
                <article class="testimonial-slide flex w-full flex-col items-center gap-4 md:gap-7">
                  <blockquote class="quote-title text-balance" cite={siteUrl}>
                    “{testimonial.quote}”
                  </blockquote>
                  <p class="eyebrow text-[color:var(--color-muted)]">{testimonial.name}</p>
                </article>
              ))
            }
          </div>
          <div id="testimonials-dots" class="carousel-dots" aria-label="Testimonials slide navigation"></div>
        </div>
      </section>
    </main>

    <footer id="contact" class="bg-[color:var(--color-brand)] py-16 text-white">
      <div class="container-shell">
        <div class="grid gap-8 lg:grid-cols-2">
          <section aria-labelledby="contact-heading">
            <h2 id="contact-heading" class="footer-heading text-balance">Contact us</h2>
            <p id="contact-intro" class="mt-2 text-[16px] leading-[26px] text-[color:var(--color-footer-subtle)]">
              Share your event details and we will contact you within one business day.
            </p>

            <form id="contact-form" class="mt-6 space-y-4" method="POST" action="https://api.web3forms.com/submit" novalidate aria-describedby="contact-intro">
              <input type="hidden" name="access_key" value={web3formsKey} />
              <input type="hidden" name="subject" value={`New inquiry from ${venueName} website`} />
              <input type="hidden" name="from_name" value={venueName} />

              <div>
                <label for="name" class="form-label">Name</label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  autocomplete="name"
                  required
                  class="form-control focus-ring"
                  placeholder="Your full name"
                />
              </div>

              <div>
                <label for="email" class="form-label">Email</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  autocomplete="email"
                  required
                  class="form-control focus-ring"
                  placeholder="name@example.com"
                />
              </div>

              <div>
                <label for="message" class="form-label">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  class="form-control focus-ring"
                  placeholder="Tell us about your event date, guest count, and vision."
                ></textarea>
              </div>

              <button
                type="submit"
                class="pill-button focus-ring rounded-[999px] bg-white px-6 py-2.5 text-[color:var(--color-submit-text)]"
              >
                Send Inquiry
              </button>

              <p id="form-status" class="min-h-[1.25rem] text-sm text-[color:var(--color-footer-light)]" role="status" aria-live="polite"></p>
            </form>

            <div
              id="form-success-panel"
              class="mt-6 hidden rounded-2xl bg-white/10 p-6 text-[color:var(--color-footer-light)]"
              role="status"
              aria-live="polite"
              aria-atomic="true"
              tabindex="-1"
            >
              <h3 class="text-balance text-xl font-[400] leading-7">Inquiry sent</h3>
              <p class="mt-2 text-[16px] leading-[26px] text-[color:var(--color-footer-subtle)]">
                Thank you for reaching out. We will contact you within one business day.
              </p>
            </div>
          </section>

          <section class="flex flex-col gap-8">
            <div>
              <h2 class="footer-heading text-balance text-white">Visit us</h2>
              <p class="mt-2 text-[16px] leading-[26px] text-[color:var(--color-footer-subtle)]">
                Visit the venue and our team will gladly walk you through the space.
              </p>
              <div class="soft-card mt-6 overflow-hidden border border-white/20">
                <a
                  class="focus-ring block"
                  href="https://www.google.com/maps/search/?api=1&query=1240+Dundas+St+E,+Belleville,+ON"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Open Legacy Events map in Google Maps (opens in a new tab)"
                >
                  <Image
                    src={mapImage}
                    alt="Map showing Legacy Events location in Belleville, Ontario"
                    width={556}
                    height={350}
                    widths={[420, 556, 900]}
                    sizes="(min-width: 1024px) 50vw, 100vw"
                    format="webp"
                    quality={74}
                    class="h-[312px] w-full object-cover md:h-[350px]"
                    loading="lazy"
                  />
                </a>
              </div>
            </div>

            <div>
              <div>
                <p class="footer-copy">
                  <a
                    class="focus-ring rounded-sm underline-offset-4 hover:underline"
                    href="https://www.google.com/maps/search/?api=1&query=1240+Dundas+St+E,+Belleville,+ON"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Open Legacy Events location in Google Maps (opens in a new tab)"
                  >
                    1240 Dundas St E, Belleville, ON
                  </a>
                </p>
                <p class="footer-copy mt-4"><a class="focus-ring rounded-sm underline-offset-4 hover:underline" href="tel:+16135550148">+1 (613) 555-0148</a></p>
                <p class="footer-copy"><a class="focus-ring rounded-sm underline-offset-4 hover:underline" href="mailto:events@legacyevents.com">events@legacyevents.com</a></p>
                <nav aria-label="Legacy Events social media">
                <ul class="mt-4 mb-8 flex items-center gap-3 md:mb-0">
                  <li>
                    <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram (opens in a new tab)" class="focus-ring inline-flex h-9 w-9 items-center justify-center rounded-full bg-white/15 text-white transition hover:bg-white/25">
                      <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 fill-current">
                        <path d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9a5.5 5.5 0 0 1-5.5 5.5h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2Zm0 2A3.5 3.5 0 0 0 4 7.5v9A3.5 3.5 0 0 0 7.5 20h9a3.5 3.5 0 0 0 3.5-3.5v-9A3.5 3.5 0 0 0 16.5 4h-9Zm9.75 1.5a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z"></path>
                      </svg>
                    </a>
                  </li>
                  <li>
                    <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook (opens in a new tab)" class="focus-ring inline-flex h-9 w-9 items-center justify-center rounded-full bg-white/15 text-white transition hover:bg-white/25">
                      <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 fill-current">
                        <path d="M13.5 22v-8h2.7l.4-3h-3.1V9.1c0-.9.2-1.6 1.6-1.6H16.8V4.8c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.4-4 4.2V11H8v3h2.4v8h3.1Z"></path>
                      </svg>
                    </a>
                  </li>
                  <li>
                    <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn (opens in a new tab)" class="focus-ring inline-flex h-9 w-9 items-center justify-center rounded-full bg-white/15 text-white transition hover:bg-white/25">
                      <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 fill-current">
                        <path d="M6.5 8.5A1.75 1.75 0 1 1 6.5 5a1.75 1.75 0 0 1 0 3.5ZM5 10h3v9H5v-9Zm5 0h2.9v1.3h.1c.4-.8 1.4-1.6 2.8-1.6 3 0 3.5 2 3.5 4.5V19h-3v-4.1c0-1 0-2.2-1.3-2.2s-1.6 1-1.6 2.1V19h-3v-9Z"></path>
                      </svg>
                    </a>
                  </li>
                </ul>
                </nav>
              </div>
            </div>
          </section>
        </div>

        <p class="footer-copy mt-20 md:mt-10">© {currentYear} Legacy Events. All rights reserved.</p>
      </div>
    </footer>

    <script>
      const form = document.getElementById('contact-form');
      const status = document.getElementById('form-status');
      const successPanel = document.getElementById('form-success-panel');
      const isMobile = window.matchMedia('(max-width: 767px)').matches;

      const setupCarouselDots = (carouselId: string, dotsId: string, mobileOnly = true) => {
        const track = document.getElementById(carouselId);
        const dotsWrap = document.getElementById(dotsId);
        if (!(track instanceof HTMLElement) || !(dotsWrap instanceof HTMLElement)) return;
        if (mobileOnly && !isMobile) return;

        const slides = Array.from(track.children).filter((el): el is HTMLElement => el instanceof HTMLElement);
        if (slides.length <= 1) return;

        dotsWrap.innerHTML = slides
          .map(
            (_, i) =>
              `<button type="button" class="carousel-dot focus-ring" aria-label="Go to slide ${i + 1}" aria-controls="${carouselId}" aria-current="${i === 0}"></button>`,
          )
          .join('');

        const dots = Array.from(dotsWrap.querySelectorAll<HTMLButtonElement>('.carousel-dot'));

        const setActiveDot = (index: number) => {
          dots.forEach((dot, i) => {
            dot.setAttribute('aria-current', i === index ? 'true' : 'false');
          });
        };

        dots.forEach((dot, i) => {
          dot.addEventListener('click', () => {
            const target = slides[i];
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            track.scrollTo({
              left: target.offsetLeft - track.offsetLeft,
              behavior: prefersReducedMotion ? 'auto' : 'smooth',
            });
            setActiveDot(i);
          });
        });

        track.addEventListener('scroll', () => {
          const trackCenter = track.scrollLeft + track.clientWidth / 2;
          let activeIndex = 0;
          let closest = Infinity;
          slides.forEach((slide, i) => {
            const slideCenter = slide.offsetLeft - track.offsetLeft + slide.clientWidth / 2;
            const distance = Math.abs(slideCenter - trackCenter);
            if (distance < closest) {
              closest = distance;
              activeIndex = i;
            }
          });
          setActiveDot(activeIndex);
        }, { passive: true });

        track.addEventListener('keydown', (event) => {
          if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) return;
          event.preventDefault();
          const currentIndexRaw = dots.findIndex((dot) => dot.getAttribute('aria-current') === 'true');
          const currentIndex = currentIndexRaw >= 0 ? currentIndexRaw : 0;

          let targetIndex = currentIndex;
          if (event.key === 'ArrowRight') targetIndex = Math.min(slides.length - 1, currentIndex + 1);
          if (event.key === 'ArrowLeft') targetIndex = Math.max(0, currentIndex - 1);
          if (event.key === 'Home') targetIndex = 0;
          if (event.key === 'End') targetIndex = slides.length - 1;

          const target = slides[targetIndex];
          const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          track.scrollTo({
            left: target.offsetLeft - track.offsetLeft,
            behavior: prefersReducedMotion ? 'auto' : 'smooth',
          });
          setActiveDot(targetIndex);
        });
      };

      setupCarouselDots('spaces-carousel', 'spaces-dots');
      setupCarouselDots('amenities-carousel', 'amenities-dots');
      setupCarouselDots('testimonials-carousel', 'testimonials-dots', false);

      const setStatus = (text: string, isError = false) => {
        if (!(status instanceof HTMLElement)) return;
        status.textContent = text;
        status.classList.toggle('text-red-200', isError);
        status.classList.toggle('text-[color:var(--color-footer-light)]', !isError);
      };

      if (form instanceof HTMLFormElement) {
        form.addEventListener('submit', async (event) => {
          event.preventDefault();

          if (!form.reportValidity()) {
            setStatus('Please complete all required fields.', true);
            return;
          }

          const accessKey = form.querySelector<HTMLInputElement>('input[name="access_key"]');
          if (!accessKey || !accessKey.value) {
            setStatus('Missing Web3Forms key. Set PUBLIC_WEB3FORMS_ACCESS_KEY in your environment.', true);
            return;
          }

          const submitButton = form.querySelector('button[type="submit"]');
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = true;
            submitButton.setAttribute('aria-disabled', 'true');
            submitButton.textContent = 'Sending...';
          }
          form.setAttribute('aria-busy', 'true');

          try {
            const payload = new FormData(form);
            const response = await fetch(form.action, {
              method: 'POST',
              body: payload,
            });

            const result = await response.json();
            if (result.success) {
              form.reset();
              form.classList.add('hidden');
              setStatus('');
              if (successPanel instanceof HTMLElement) {
                successPanel.classList.remove('hidden');
                successPanel.focus();
              }
            } else {
              setStatus(result.message || 'Submission failed. Please try again.', true);
            }
          } catch {
            setStatus('Network error. Please try again in a moment.', true);
          } finally {
            form.setAttribute('aria-busy', 'false');
            if (submitButton instanceof HTMLButtonElement) {
              submitButton.disabled = false;
              submitButton.removeAttribute('aria-disabled');
              submitButton.textContent = 'Send Inquiry';
            }
          }
        });
      }
    </script>
    <Analytics />
    <SpeedInsights />
  </body>
</html>
